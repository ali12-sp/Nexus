NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus?schema=public
JWT_SECRET=change-this-super-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=nexus_rt
COOKIE_DOMAIN=
COOKIE_SECURE=false
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=24
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
STRIPE_SECRET_KEY=
PAYMENT_PROVIDER=MOCK
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexus.local
OTP_EXPIRY_MINUTES=10
