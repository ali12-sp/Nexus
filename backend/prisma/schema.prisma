generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  INVESTOR
  ENTREPRENEUR
}

enum MeetingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum DocumentStatus {
  UPLOADED
  UNDER_REVIEW
  SIGNED
  ARCHIVED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MOCK
}

enum OtpChannel {
  EMAIL
}

enum OtpPurpose {
  LOGIN
  SENSITIVE_ACTION
}

enum NotificationType {
  MEETING
  DOCUMENT
  PAYMENT
  SECURITY
  SYSTEM
}

model User {
  id                  String          @id @default(cuid())
  fullName            String
  email               String          @unique
  passwordHash        String
  role                UserRole
  bio                 String?
  profileImage        String?
  location            String?
  website             String?
  preferences         Json?
  startupName         String?
  startupStage        String?
  industry            String?
  pitchSummary        String?
  fundingNeeded       Decimal?        @db.Decimal(12, 2)
  previousFunding     String?
  firmName            String?
  investmentFocus     String?
  ticketSizeMin       Decimal?        @db.Decimal(12, 2)
  ticketSizeMax       Decimal?        @db.Decimal(12, 2)
  portfolioHistory    String?
  preferredIndustries String[]
  walletBalance       Decimal         @default(0) @db.Decimal(12, 2)
  twoFactorEnabled    Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  meetingsOrganized   Meeting[]       @relation("OrganizerMeetings")
  meetingsInvited     Meeting[]       @relation("InviteeMeetings")
  documents           Document[]
  signatures          Signature[]
  transactions        Transaction[]   @relation("UserTransactions")
  transfersReceived   Transaction[]   @relation("RecipientTransactions")
  otpCodes            TwoFactorCode[]
  notifications       Notification[]
}

model Meeting {
  id          String        @id @default(cuid())
  organizerId String
  inviteeId   String
  title       String
  agenda      String?
  notes       String?
  startTime   DateTime
  endTime     DateTime
  timezone    String
  status      MeetingStatus @default(PENDING)
  roomId      String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  organizer   User          @relation("OrganizerMeetings", fields: [organizerId], references: [id], onDelete: Cascade)
  invitee     User          @relation("InviteeMeetings", fields: [inviteeId], references: [id], onDelete: Cascade)
  documents   Document[]

  @@index([organizerId, startTime, endTime])
  @@index([inviteeId, startTime, endTime])
  @@index([status])
}

model Document {
  id               String         @id @default(cuid())
  title            String
  fileUrl          String
  fileKey          String
  fileType         String
  fileSize         Int
  uploadedById     String
  version          Int            @default(1)
  versionGroupId   String         @default(cuid())
  status           DocumentStatus @default(UPLOADED)
  relatedMeetingId String?
  signatureUrl     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  uploadedBy       User           @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  relatedMeeting   Meeting?       @relation(fields: [relatedMeetingId], references: [id], onDelete: SetNull)
  signatures       Signature[]

  @@index([uploadedById, createdAt])
  @@index([relatedMeetingId])
  @@index([versionGroupId, version])
}

model Signature {
  id           String   @id @default(cuid())
  documentId   String
  signedById   String
  signerName   String
  signatureUrl String
  ipAddress    String?
  metadata     Json?
  signedAt     DateTime @default(now())
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signedBy     User     @relation(fields: [signedById], references: [id], onDelete: Cascade)

  @@index([documentId, signedAt])
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  type              TransactionType
  amount            Decimal           @db.Decimal(12, 2)
  currency          String            @default("USD")
  status            TransactionStatus @default(PENDING)
  provider          PaymentProvider   @default(MOCK)
  reference         String            @unique
  note              String?
  recipientUserId   String?
  externalReference String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  recipientUser     User?             @relation("RecipientTransactions", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([recipientUserId, createdAt])
}

model TwoFactorCode {
  id         String      @id @default(cuid())
  userId     String
  code       String
  channel    OtpChannel  @default(EMAIL)
  purpose    OtpPurpose  @default(LOGIN)
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
